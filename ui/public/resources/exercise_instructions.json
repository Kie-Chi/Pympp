[
  {
    "name": "add",
    "syntax": "add $rd, $rs, $rt",
    "description": "Add Word: $rd = $rs + $rt",
    "tuse_rs": [1],
    "tuse_rt": [1],
    "tnew": [2],
    "example": "examples/add.asm"
  },
  {
    "name": "sub",
    "syntax": "sub $rd, $rs, $rt",
    "description": "Subtract Word: $rd = $rs - $rt",
    "tuse_rs": [1],
    "tuse_rt": [1],
    "tnew": [2],
    "example": "examples/sub.asm"
  },
  {
    "name": "ori",
    "syntax": "ori $rt, $rs, imm",
    "description": "Or Immediate: $rt = $rs | imm",
    "tuse_rs": [1],
    "tuse_rt": [null],
    "tnew": [2],
    "example": "examples/ori.asm"
  },
  {
    "name": "lui",
    "syntax": "lui $rt, imm",
    "description": "Load Upper Immediate: $rt = imm << 16",
    "tuse_rs": [null],
    "tuse_rt": [null],
    "tnew": [2],
    "example": "examples/lui.asm"
  },
  {
    "name": "lw",
    "syntax": "lw $rt, offset($rs)",
    "description": "Load Word: $rt = MEM[$rs + offset]",
    "tuse_rs": [1],
    "tuse_rt": [null],
    "tnew": [3],
    "example": "examples/lw.asm"
  },
  {
    "name": "sw",
    "syntax": "sw $rt, offset($rs)",
    "description": "Store Word: MEM[$rs + offset] = $rt",
    "tuse_rs": [1],
    "tuse_rt": [2],
    "tnew": [null],
    "example": "examples/sw.asm"
  },
  {
    "name": "beq",
    "syntax": "beq $rs, $rt, label",
    "description": "Branch on Equal: if $rs == $rt goto label",
    "tuse_rs": [0],
    "tuse_rt": [0],
    "tnew": [null],
    "example": "examples/beq.asm"
  },
  {
    "name": "jal",
    "syntax": "jal label",
    "description": "Jump and Link: $ra = PC+8; goto label",
    "tuse_rs": [null],
    "tuse_rt": [null],
    "tnew": [1],
    "example": "examples/jal.asm"
  },
  {
    "name": "jr",
    "syntax": "jr $rs",
    "description": "Jump Register: goto $rs",
    "tuse_rs": [0],
    "tuse_rt": [null],
    "tnew": [null],
    "example": "examples/jr.asm"
  }
]