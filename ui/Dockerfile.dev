# Development mode Dockerfile for frontend
# Uses Vite dev server with hot reload

FROM node:20-alpine

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm ci

# Copy source files (will be mounted in dev mode, but copy for initial build)
COPY . .

# Expose Vite dev server port
EXPOSE 5173

# Run Vite dev server with host flag for Docker access
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]